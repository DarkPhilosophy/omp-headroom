{
  "name": "omp-headroom",
  "version": "0.1.0-beta.3",
  "description": "Headroom context-compression integration for OMP: proxy lifecycle, tool-output compression, session archive compaction with CCR retrieval, adaptive thresholds, and a live savings widget.",
  "author": "DarkPhilosophy",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DarkPhilosophy/omp-headroom.git"
  },
  "keywords": [
    "omp",
    "headroom",
    "llm",
    "context",
    "compression",
    "token",
    "proxy",
    "rocm",
    "cuda"
  ],
  "files": [
    "src",
    "plugins/headroom-omp-stats",
    "systemd",
    "README.md",
    ".github/CHANGELOG.md",
    "LICENSE"
  ],
  "exports": "./src/index.ts",
  "omp": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "scan": "bun .scripts/scan-leaks.mjs",
    "lint:py": "ruff check plugins",
    "verify": "bun run check && bun run typecheck && bun run test && bun run scan"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "^16.4.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@oh-my-pi/pi-coding-agent": "16.4.4",
    "@types/bun": "^1.3.5",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@opentelemetry/core": "2.8.0"
  }
}
